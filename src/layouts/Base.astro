---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: "en" | "es";
  altLangUrl?: string | null;
}

const {
  title,
  description = "Erik Escobedo — Software Engineer with 16+ years of experience. Ex-Google Classroom.",
  ogImage = "/og-default.png",
  lang = "en",
  altLangUrl = null,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang} data-theme-pref="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {
      altLangUrl && (
        <link
          rel="alternate"
          hreflang={lang === "en" ? "es" : "en"}
          href={new URL(altLangUrl, Astro.site)}
        />
      )
    }
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={lang === "en"
        ? canonicalURL
        : altLangUrl
          ? new URL(altLangUrl, Astro.site)
          : canonicalURL}
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      (function () {
        var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.setAttribute(
          "data-theme",
          dark ? "dark" : "light",
        );
        document.documentElement.setAttribute("data-theme-pref", "system");
      })();
    </script>
    <script
      defer
      src="https://analytics.escobedo.dev/script.js"
      data-website-id="75b67fd4-12c9-4f9c-8ca3-ccd1d08f3114"></script>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href={lang === "es" ? "/es" : "/"} class="nav-logo">
          <span class="logo-e" style="color:var(--blue)">E</span><span
            class="logo-e"
            style="color:var(--red)">r</span
          ><span class="logo-e" style="color:var(--yellow)">i</span><span
            class="logo-e"
            style="color:var(--green)">k</span
          >
        </a>
        <div class="nav-links">
          {
            altLangUrl && (
              <div class="nav-lang-switch">
                {lang === "en" ? (
                  <>
                    <span class="nlang-active">EN</span>
                    <span class="nlang-sep">·</span>
                    <a href={altLangUrl} class="nlang-link">
                      ES
                    </a>
                  </>
                ) : (
                  <>
                    <a href={altLangUrl} class="nlang-link">
                      EN
                    </a>
                    <span class="nlang-sep">·</span>
                    <span class="nlang-active">ES</span>
                  </>
                )}
              </div>
            )
          }
          <div class="theme-switch">
            <button
              class="theme-opt to-light"
              data-theme="light"
              aria-label="Light theme"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
              >
                <circle cx="8" cy="8" r="3"></circle>
                <line x1="8" y1="1" x2="8" y2="2.5"></line>
                <line x1="8" y1="13.5" x2="8" y2="15"></line>
                <line x1="1" y1="8" x2="2.5" y2="8"></line>
                <line x1="13.5" y1="8" x2="15" y2="8"></line>
                <line x1="3.1" y1="3.1" x2="4.2" y2="4.2"></line>
                <line x1="11.8" y1="11.8" x2="12.9" y2="12.9"></line>
                <line x1="12.9" y1="3.1" x2="11.8" y2="4.2"></line>
                <line x1="4.2" y1="11.8" x2="3.1" y2="12.9"></line>
              </svg>
            </button>
            <span class="theme-sep">·</span>
            <button
              class="theme-opt to-dark"
              data-theme="dark"
              aria-label="Dark theme"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M13.5 10.5A6 6 0 0 1 5.5 2.5a6 6 0 1 0 8 8z"></path>
              </svg>
            </button>
            <span class="theme-sep">·</span>
            <button
              class="theme-opt to-system"
              data-theme="system"
              aria-label="System theme"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="1" y="2" width="14" height="10" rx="1.5"></rect>
                <line x1="5" y1="15" x2="11" y2="15"></line>
                <line x1="8" y1="12" x2="8" y2="15"></line>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <script>
      type ThemePref = "system" | "dark" | "light";

      function applyTheme(pref: ThemePref) {
        const dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const resolved = pref === "system" ? (dark ? "dark" : "light") : pref;
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-pref", pref);
        localStorage.setItem("theme", pref);
      }

      document
        .querySelectorAll<HTMLButtonElement>(".theme-opt")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            applyTheme(btn.dataset.theme as ThemePref);
          });
        });

      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", () => {
          applyTheme("system");
        });

      document
        .querySelector(".nlang-link")
        ?.addEventListener("click", function (e) {
          const hash = window.location.hash;
          if (hash) {
            e.preventDefault();
            window.location.href = (this as HTMLAnchorElement).href + hash;
          }
        });
    </script>

    <footer class="footer">
      <div class="footer-inner">
        <span class="footer-copy"
          >© {new Date().getFullYear()} Erik Escobedo</span
        >
        <div class="footer-links">
          <a href="https://github.com/escoberik" target="_blank" rel="noopener"
            >GitHub</a
          >
          <a href="mailto:erik@escobedo.dev">Email</a>
          <a
            href="https://www.toptal.com/developers/resume/erik-escobedo"
            target="_blank"
            rel="noopener">Toptal</a
          >
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  /* ---- Nav ---- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    display: flex;
    align-items: baseline;
    gap: 0;
  }
  .logo-e {
    font-weight: 700;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    font-size: 0.875rem;
    color: var(--text-2);
  }
  .nav-links a {
    transition: color 0.15s;
  }
  .nav-links a:hover {
    color: var(--text);
  }

  /* ---- Theme switch ---- */
  .theme-switch {
    display: none;
  }
  .theme-sep {
    color: var(--border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    user-select: none;
  }
  .theme-opt {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    color: var(--blue);
    border-bottom: 1px solid rgba(79, 133, 244, 0.3);
    transition:
      border-color 0.15s,
      color 0.15s;
    line-height: 1;
  }
  .theme-opt:hover {
    border-color: var(--blue);
  }
  /* active state — matches .lang-opt.active */
  [data-theme-pref="light"] .to-light,
  [data-theme-pref="dark"] .to-dark,
  [data-theme-pref="system"] .to-system,
  :not([data-theme-pref]) .to-system {
    color: var(--text);
    border-bottom-color: transparent;
    cursor: default;
  }

  /* ---- Nav lang switch ---- */
  .nav-lang-switch {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    margin-left: 0.5rem;
  }
  .nlang-active {
    color: var(--text);
    font-weight: 600;
  }
  .nlang-sep {
    color: var(--border);
  }
  .nlang-link {
    color: var(--blue);
    border-bottom: 1px solid rgba(79, 133, 244, 0.3);
    transition: border-color 0.15s;
  }
  .nlang-link:hover {
    border-color: var(--blue);
  }

  /* ---- Footer ---- */
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 6rem;
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-3);
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a:hover {
    color: var(--text-2);
  }

  @media (max-width: 640px) {
    .nav {
      padding: 0 1.5rem;
    }
    .nav-links {
      gap: 1rem;
    }
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
      padding: 1.5rem;
    }
  }
</style>
