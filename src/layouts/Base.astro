---
import { analytics } from "../config/site";
import Icon from "../components/Icon.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: "en" | "es";
  altLangUrl?: string | null;
}

const {
  title,
  description = "Erik Escobedo — Software Engineer with 16+ years of experience. Ex-Google Classroom.",
  ogImage = "/og-default.png",
  lang = "en",
  altLangUrl = null,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang} data-theme-pref="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {
      altLangUrl && (
        <link
          rel="alternate"
          hreflang={lang === "en" ? "es" : "en"}
          href={new URL(altLangUrl, Astro.site)}
        />
      )
    }
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={lang === "en"
        ? canonicalURL
        : altLangUrl
          ? new URL(altLangUrl, Astro.site)
          : canonicalURL}
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      (function () {
        var pref = localStorage.getItem("theme") || "system";
        var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var resolved = pref === "system" ? (dark ? "dark" : "light") : pref;
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-pref", pref);
      })();
    </script>
    <script
      defer
      src={analytics.url}
      data-website-id={analytics.websiteId}
      data-domains={analytics.domains}></script>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href={lang === "es" ? "/es" : "/"} class="nav-logo">
          <span class="logo-e" style="color:var(--blue)">E</span><span
            class="logo-e"
            style="color:var(--red)">r</span
          ><span class="logo-e" style="color:var(--yellow)">i</span><span
            class="logo-e"
            style="color:var(--green)">k</span
          >
        </a>
        <div class="nav-links">
          {
            altLangUrl && (
              <div class="nav-lang-switch">
                <div class="nlang-theme">
                  <button class="theme-opt to-light" data-theme="light" aria-label="Light theme">
                    <Icon name="sun" size={20} />
                  </button>
                  <button class="theme-opt to-dark" data-theme="dark" aria-label="Dark theme">
                    <Icon name="moon" size={20} />
                  </button>
                  <button class="theme-opt to-system" data-theme="system" aria-label="System theme">
                    <Icon name="system" size={20} />
                  </button>
                  <span class="nlang-sep"></span>
                </div>
                <a
                  href={altLangUrl}
                  class="nlang-other"
                  aria-label={lang === "en" ? "Español" : "English"}
                >
                  <span class="flag-wrap">
                    {lang === "en" ? "🇲🇽" : "🇺🇸"}
                    <span class="flag-badge">{lang === "en" ? "es" : "en"}</span>
                  </span>
                </a>
                <span
                  class="nlang-current"
                  aria-label={lang === "en" ? "English" : "Español"}
                >
                  <span class="flag-wrap">
                    {lang === "en" ? "🇺🇸" : "🇲🇽"}
                    <span class="flag-badge">{lang === "en" ? "en" : "es"}</span>
                    <span class="theme-badge">
                      <span class="tb-light"><Icon name="sun" size={8} strokeWidth={2.5} /></span>
                      <span class="tb-dark"><Icon name="moon" size={8} strokeWidth={2.5} /></span>
                    </span>
                  </span>
                </span>
              </div>
            )
          }
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <script>
      type ThemePref = "system" | "dark" | "light";

      function applyTheme(pref: ThemePref) {
        document.documentElement.classList.add("theme-transition");
        const dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const resolved = pref === "system" ? (dark ? "dark" : "light") : pref;
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-pref", pref);
        localStorage.setItem("theme", pref);
        window.setTimeout(() => {
          document.documentElement.classList.remove("theme-transition");
        }, 400);
      }

      document
        .querySelectorAll<HTMLButtonElement>(".theme-opt")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            applyTheme(btn.dataset.theme as ThemePref);
          });
        });

      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", () => {
          applyTheme("system");
        });

      document
        .querySelector(".nlang-other")
        ?.addEventListener("click", function (this: HTMLAnchorElement, e) {
          const hash = window.location.hash;
          if (hash) {
            e.preventDefault();
            window.location.href = this.href + hash;
          }
        });

      const langSwitch = document.querySelector(".nav-lang-switch");
      langSwitch?.addEventListener("mouseenter", () => langSwitch.classList.add("is-open"));
      langSwitch?.addEventListener("mouseleave", () => langSwitch.classList.remove("is-open"));
      document.querySelector(".nlang-current")?.addEventListener("click", () => {
        langSwitch?.classList.toggle("is-open");
      });
      window.addEventListener("scroll", () => langSwitch?.classList.remove("is-open"), { passive: true });
    </script>

    <footer class="footer">
      <div class="footer-inner">
        <span class="footer-copy"
          >© {new Date().getFullYear()} Erik Escobedo</span
        >
        <div class="footer-links">
          <a href="https://github.com/escoberik" target="_blank" rel="noopener"
            >GitHub</a
          >
          <a href="mailto:erik@escobedo.dev">Email</a>
          <a
            href="https://www.toptal.com/developers/resume/erik-escobedo"
            target="_blank"
            rel="noopener">Toptal</a
          >
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  /* ---- Nav ---- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    display: flex;
    align-items: baseline;
    gap: 0;
  }
  .logo-e {
    font-weight: 700;
  }
  .nav-links {
    display: flex;
    align-items: center;
    align-self: stretch;
    gap: 2rem;
    font-size: 0.875rem;
    color: var(--text-2);
  }

  /* ---- Theme switch ---- */
  .theme-sep {
    color: var(--border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    user-select: none;
  }
  .theme-opt {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    color: var(--blue);
    border-bottom: 1px solid rgba(79, 133, 244, 0.3);
    transition:
      border-color 0.15s,
      color 0.15s;
    line-height: 1;
  }
  .theme-opt:hover {
    border-color: var(--blue);
  }
  /* active state */
  [data-theme-pref="light"] .to-light,
  [data-theme-pref="dark"] .to-dark,
  [data-theme-pref="system"] .to-system,
  :not([data-theme-pref]) .to-system {
    color: var(--text);
    border-bottom-color: transparent;
    cursor: default;
  }

  /* ---- Nav lang switch ---- */
  .nav-lang-switch {
    display: flex;
    align-items: center;
    justify-content: right;
    align-self: stretch;
    gap: 1.2rem;
    margin-left: 0.5rem;
    font-size: 1.5rem;
    padding: 0 0.75rem;
    overflow: hidden;
    max-width: 3.5rem;
    background: rgba(255, 255, 255, 0);
    border: 1px solid rgba(255, 255, 255, 0);
    border-radius: 1rem;
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    transition:
      max-width 0.35s ease,
      background 0.25s ease,
      border-color 0.25s ease;
  }
  .nav-lang-switch.is-open {
    max-width: 13rem;
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.13);
  }
  [data-theme="light"] .nav-lang-switch {
    background: rgba(0, 0, 0, 0);
    border-color: rgba(0, 0, 0, 0);
  }
  [data-theme="light"] .nav-lang-switch.is-open {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.09);
  }
  .nlang-current {
    line-height: 1;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-lang-switch.is-open .nlang-other {
    opacity: 1;
  }
  .nlang-theme {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-right: -0.7rem;
    opacity: 0;
    transition: opacity 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-lang-switch.is-open .nlang-theme {
    opacity: 1;
  }
  .nlang-theme .theme-opt {
    color: rgba(255, 255, 255, 0.45);
    border-bottom: none;
    cursor: pointer;
  }
  .nlang-theme .theme-opt:hover {
    color: rgba(255, 255, 255, 0.85);
  }
  [data-theme-pref="light"] .nlang-theme .to-light,
  [data-theme-pref="dark"] .nlang-theme .to-dark,
  [data-theme-pref="system"] .nlang-theme .to-system {
    color: rgba(255, 255, 255, 0.95);
  }
  [data-theme="light"] .nlang-theme .theme-opt {
    color: rgba(0, 0, 0, 0.3);
    border-bottom: none;
  }
  [data-theme="light"] .nlang-theme .theme-opt:hover {
    color: rgba(0, 0, 0, 0.7);
  }
  [data-theme="light"][data-theme-pref="light"] .nlang-theme .to-light,
  [data-theme="light"][data-theme-pref="dark"] .nlang-theme .to-dark,
  [data-theme="light"][data-theme-pref="system"] .nlang-theme .to-system {
    color: rgba(0, 0, 0, 0.85);
  }
  .nlang-sep {
    width: 1px;
    align-self: stretch;
    background: var(--border);
    margin: 0.6rem 0.15rem;
    opacity: 0.5;
  }
  .nlang-other {
    /* display: none; */
    line-height: 1;
    opacity: 0;
    transition: opacity 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .flag-wrap {
    position: relative;
    display: inline-flex;
    line-height: 1;
  }
  .theme-badge {
    position: absolute;
    top: -7px;
    right: -10px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.15em;
    color: var(--text-2);
    pointer-events: none;
    user-select: none;
  }
  [data-theme-pref="light"] .theme-badge,
  [data-theme-pref="dark"] .theme-badge {
    display: flex;
  }
  .tb-light, .tb-dark, .tb-system {
    display: none;
    line-height: 1;
  }
  [data-theme-pref="light"] .tb-light,
  [data-theme-pref="dark"] .tb-dark {
    display: flex;
  }
  .flag-badge {
    position: absolute;
    bottom: -6px;
    right: -10px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.15em 0.3em;
    color: var(--text-2);
    letter-spacing: 0.03em;
    pointer-events: none;
    user-select: none;
  }

  /* ---- Footer ---- */
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 6rem;
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-3);
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a:hover {
    color: var(--text-2);
  }

  @media (max-width: 640px) {
    .nav {
      padding: 0 1.5rem;
    }
    .nav-links {
      gap: 1rem;
    }
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
      padding: 1.5rem;
    }
  }
</style>
