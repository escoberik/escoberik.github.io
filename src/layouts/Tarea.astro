---
import Base from './Base.astro'

interface Props {
  title: string
}

const { title } = Astro.props
---

<Base title={title} lang="es">
  <article class="tarea">
    <div class="tarea-body">
      <slot />
    </div>
  </article>
</Base>

<style>
  .tarea {
    max-width: var(--prose-w);
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .tarea-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }
</style>

<style is:global>
  /* Title */
  .tarea-body h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  /* First paragraph after title becomes a subtitle */
  .tarea-body h1 + p {
    font-size: 1rem;
    color: var(--text-2);
    margin-bottom: 2.5rem;
    border-left: 2px solid var(--blue);
    padding-left: 0.875rem;
  }

  /* Level headings */
  .tarea-body h2 {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin: 3rem 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* Italic subtitle under each level heading */
  .tarea-body h2 + p {
    font-size: 0.875rem;
    color: var(--text-2);
    font-style: italic;
    margin-bottom: 1rem;
    margin-top: -0.75rem;
  }

  /* Exercise list */
  .tarea-body ol {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tarea-body li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.6rem 1rem;
    counter-increment: exercise;
    font-size: 1rem;
    transition: border-color 0.15s, background 0.15s;
  }

  .tarea-body li:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: var(--bg-3);
  }

  [data-theme='light'] .tarea-body li:hover {
    border-color: rgba(0, 0, 0, 0.15);
  }

  /* Counter badge */
  .tarea-body li::before {
    content: counter(exercise);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-3);
    min-width: 1.25rem;
    text-align: right;
    flex-shrink: 0;
    padding-top: 0.05em;
  }

  /* Reset counter per ordered list */
  .tarea-body ol {
    counter-reset: exercise;
  }

  /* Dividers */
  .tarea-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  /* Tip callout (bold text at end) */
  .tarea-body p:last-child {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--yellow);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-size: 0.925rem;
    color: var(--text-2);
    margin-top: 2rem;
  }

  /* KaTeX sizing */
  .tarea-body .katex {
    font-size: 1em;
  }
</style>
