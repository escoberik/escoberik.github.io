---
import Base from './Base.astro'

interface Props {
  title: string
  description: string
  pubDate: Date
  tags?: string[]
}

const { title, description, pubDate, tags = [] } = Astro.props

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<Base title={`${title} — Erik Escobedo`} description={description}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>
    </header>

    <div class="post-body">
      <slot />
    </div>
  </article>
</Base>

<style is:global>
  .post {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .post-header {
    max-width: var(--prose-w);
    margin: 0 auto 3.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
    color: var(--text-3);
    font-family: var(--font-mono);
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--bg-3);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    color: var(--text-2);
    font-size: 0.75rem;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.1rem;
    color: var(--text-2);
    line-height: 1.6;
    border-left: 2px solid var(--blue);
    padding-left: 1rem;
  }

  /* ---- Prose body ---- */
  .post-body {
    max-width: var(--prose-w);
    margin: 0 auto;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }

  .post-body h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 3rem 0 1rem;
    color: var(--text);
  }

  .post-body h3 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    margin: 2.5rem 0 0.75rem;
    color: var(--text);
  }

  .post-body p {
    margin-bottom: 1.5rem;
    color: rgba(235, 235, 235, 0.85);
  }

  .post-body a {
    color: var(--blue);
    border-bottom: 1px solid rgba(79, 133, 244, 0.3);
    transition: border-color 0.15s;
  }
  .post-body a:hover { border-color: var(--blue); }

  .post-body ul, .post-body ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .post-body li { margin-bottom: 0.4rem; }

  .post-body code {
    font-size: 0.875em;
    background: var(--bg-3);
    border: 1px solid var(--border);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    color: #c9d1d9;
  }

  .post-body pre {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.75rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .post-body pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    color: #c9d1d9;
  }

  .post-body blockquote {
    border-left: 2px solid var(--yellow);
    margin: 2rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    color: var(--text-2);
    font-style: italic;
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  /* Full-width embed breakout */
  .post-body .embed-breakout {
    width: 100vw;
    max-width: none;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    padding: 2rem 2rem;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .post-body .embed-breakout > * {
    max-width: 900px;
    margin: 0 auto;
  }
</style>
