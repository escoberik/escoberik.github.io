---
import { getCollection } from 'astro:content'
import BlogPost from '../../layouts/BlogPost.astro'
import { transformSlug } from '../../utils/i18n'

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).filter(p => !p.data.draft)

  return allPosts
    .filter(p => p.data.lang === 'en')
    .map(post => {
      const base = transformSlug(post.slug)
      const altSlug = post.data.alternateSlug ?? base
      const hasEs = allPosts.some(p => p.data.lang === 'es' && transformSlug(p.slug) === altSlug)
      return {
        params: { slug: base },
        props: { post, altLangUrl: hasEs ? `/es/blog/${altSlug}` : null },
      }
    })
}

const { post, altLangUrl } = Astro.props
const { Content } = await post.render()
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  lang="en"
  altLangUrl={altLangUrl}
>
  <Content />
</BlogPost>
