---
import Base from "../../../layouts/Base.astro";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const { lang } = Astro.params as { lang: "en" | "es" };

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({ ...p, slug: p.slug.replace(new RegExp(`-${lang}$`), "") }));

const isEs = lang === "es";
const locale = isEs ? "es-ES" : "en-US";
const altLang = isEs ? "en" : "es";
---

<Base
  title="Blog — Erik Escobedo"
  description={isEs
    ? "Notas sobre ingeniería de software, diseño de sistemas y lanzamientos de código abierto."
    : "Writing about software engineering, systems design, algorithms, and open-source work."}
  lang={lang}
>
  <div class="page">
    <header class="page-header">
      <div class="page-eyebrow-row">
        <p class="page-eyebrow">{isEs ? "Notas" : "Writing"}</p>
        <div class="lang-switch">
          <a href={`/blog/${altLang}`} class={`lang-opt ${altLang}`}
            >{altLang.toUpperCase()}</a
          >
          <span class="lang-sep">·</span>
          <span class="lang-opt active">{lang.toUpperCase()}</span>
        </div>
      </div>
      <p class="page-subtitle">
        {
          isEs
            ? "Notas sobre ingeniería de software, diseño de sistemas y el ocasional lanzamiento de código abierto."
            : "Notes on software engineering, systems design, and the occasional open-source release."
        }
      </p>
    </header>

    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/${lang}`} class="post-card">
              <div class="post-card-body">
                <h2 class="post-card-title">{post.data.title}</h2>
                <p class="post-card-desc">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-card-tags">
                    {post.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="post-card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString(locale, {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                <span class="post-card-arrow">→</span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Base>

<style>
  .page {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
  }

  .page-header {
    max-width: var(--prose-w);
    margin: 0 auto 4rem;
  }

  .page-eyebrow-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .page-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }
  .lang-opt {
    color: var(--text-3);
  }
  .lang-opt.active {
    color: var(--text);
    font-weight: 600;
  }
  .lang-opt a,
  a.lang-opt {
    color: var(--blue);
    border-bottom: 1px solid rgba(79, 133, 244, 0.3);
    transition: border-color 0.15s;
  }
  a.lang-opt:hover {
    border-color: var(--blue);
  }
  .lang-sep {
    color: var(--border);
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .page-subtitle {
    font-size: 1.05rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
    max-width: var(--prose-w);
    margin: 0 auto;
  }

  .post-card {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    transition: all 0.2s;
  }
  .post-card:first-of-type {
    border-top: 1px solid var(--border);
  }

  .post-card:hover .post-card-title {
    color: var(--blue);
  }
  .post-card:hover .post-card-arrow {
    color: var(--blue);
    transform: translateX(4px);
  }

  .post-card-body {
    flex: 1;
  }

  .post-card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
    transition: color 0.15s;
    line-height: 1.35;
  }

  .post-card-desc {
    font-size: 0.875rem;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .post-card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-3);
  }

  .post-card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  .post-card-meta time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-3);
    white-space: nowrap;
  }

  .post-card-arrow {
    font-size: 0.9rem;
    color: var(--text-3);
    transition:
      color 0.15s,
      transform 0.15s;
    display: inline-block;
  }

  @media (max-width: 640px) {
    .page {
      padding: 3rem 1.5rem 6rem;
    }
    .post-card {
      flex-direction: column;
      gap: 0.75rem;
    }
    .post-card-meta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
