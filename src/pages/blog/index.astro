---
import { getCollection } from 'astro:content'
import { transformSlug } from '../../utils/i18n'
import BlogIndex from '../../components/BlogIndex.astro'

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(p => ({ ...p, slug: transformSlug(p.slug) }))
---

<BlogIndex
  lang="en"
  title="Blog — Erik Escobedo"
  description="Writing about software engineering, systems design, algorithms, and open-source work."
  altLangUrl="/es/blog"
  eyebrow="Writing"
  subtitle="Notes on software engineering, systems design, and the occasional open-source release."
  postHrefPrefix="/blog/"
  posts={posts}
/>
