---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { transformSlug, getLocaleFromLang } from '../../utils/i18n'

const lang = 'es'
const locale = getLocaleFromLang(lang)

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map(p => ({ ...p, slug: transformSlug(p.slug) }))
---

<Base
  title="Erik Escobedo — Ingeniero de Software"
  lang="es"
  altLangUrl="/"
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">
        <span class="dot dot-blue"></span>
        <span>Disponible para nuevas oportunidades</span>
      </div>
      <h1 class="hero-name">
        <span class="hn-erik"><span style="color:var(--blue)">E</span><span style="color:var(--red)">r</span><span style="color:var(--yellow)">i</span><span style="color:var(--green)">k</span></span>
        <span class="hn-escobedo">Escobedo</span>
      </h1>
      <p class="hero-title">Ingeniero de Software</p>
      <p class="hero-bio">
        Más de 16 años construyendo sistemas a escala. Tres años en{' '}
        <span class="g-google">
          <span style="color:var(--blue)">G</span><span style="color:var(--red)">o</span><span style="color:var(--yellow)">o</span><span style="color:var(--blue)">g</span><span style="color:var(--green)">l</span><span style="color:var(--red)">e</span>
        </span>{' '}
        Classroom, donde lideré migraciones de API para millones de usuarios y retiré plataformas heredadas sin interrupciones. Me especializo en desenredar la complejidad y hacerla desaparecer.
      </p>
      <div class="hero-actions">
        <a href="/resume.pdf" class="btn btn-primary" target="_blank" rel="noopener">
          Currículum <span class="btn-arrow">↗</span>
        </a>
        <a href="/es/blog" class="btn btn-ghost">Ver el blog</a>
        <a href="mailto:erik@escobedo.dev" class="btn btn-ghost">Contacto</a>
      </div>
    </div>
    <div class="hero-decoration" aria-hidden="true">
      <div class="deco-grid"></div>
    </div>
  </section>

  <!-- Experience timeline -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-label">Experiencia</h2>
      <div class="timeline">
        <div class="timeline-item">
          <div class="tl-left">
            <span class="tl-dot" style="background:var(--blue)"></span>
            <span class="tl-year">2023 – 2026</span>
          </div>
          <div class="tl-right">
            <span class="tl-company">Google</span>
            <span class="tl-role">Software Engineer · Google Classroom</span>
            <p class="tl-desc">
              Diseñé migraciones de base de datos para millones de usuarios con Dark Launch.
              Arquitecté un sandbox SIS sintético para pruebas de integración de agentes de IA.
              Lideré el proceso EOL de una plataforma heredada. Co-escribí una suite de pruebas SQLT integral.
            </p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="tl-left">
            <span class="tl-dot" style="background:var(--text-3)"></span>
            <span class="tl-year">2018 – 2022</span>
          </div>
          <div class="tl-right">
            <span class="tl-company">FanMaker</span>
            <span class="tl-role">Software Engineer</span>
            <p class="tl-desc">
              Mantuve más de 30 apps iOS/Android sobre un backend Rails compartido.
              Escalé infraestructura AWS a más de 1M usuarios simultáneos con auto-scaling predictivo.
              Desarrollé un motor de contabilidad de partida doble para moneda virtual.
            </p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="tl-left">
            <span class="tl-dot" style="background:var(--text-3)"></span>
            <span class="tl-year">2013 – 2018</span>
          </div>
          <div class="tl-right">
            <span class="tl-company">Freelance</span>
            <span class="tl-role">Fundador y Líder de Equipo</span>
            <p class="tl-desc">
              Fundé un equipo de ingenieros locales trabajando con clientes de EEUU.
              Responsable de arquitectura, alcance y mentoría.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured project -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-label">Código Abierto</h2>
      <a href="/es/blog/rbtree-visualizer" class="project-card">
        <div class="project-card-header">
          <div class="project-name">rbtrees</div>
          <div class="project-npm">npm ↗</div>
        </div>
        <p class="project-desc">
          Un visualizador interactivo de Árboles Rojo-Negro construido en React.
          Inserta, busca o elimina un valor y recorre cada comparación, rotación y recoloración
          del algoritmo, cuadro a cuadro.
        </p>
        <div class="project-tags">
          <span class="ptag">React</span>
          <span class="ptag">TypeScript</span>
          <span class="ptag">SVG</span>
          <span class="ptag">Algorithms</span>
        </div>
        <div class="project-footer">
          <span class="project-read">Leer el post →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Writing -->
  {posts.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <h2 class="section-label">Notas</h2>
        <ul class="post-list">
          {posts.map(post => (
            <li>
              <a href={`/es/blog/${post.slug}`} class="post-row">
                <span class="post-row-title">{post.data.title}</span>
                <time class="post-row-date" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </a>
            </li>
          ))}
        </ul>
        <a href="/es/blog" class="see-all">Ver todas →</a>
      </div>
    </section>
  )}
</Base>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: calc(100vh - 56px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 5rem 2rem 6rem;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.1s;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-blue {
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
    animation: pulse-dot 2.5s ease infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-name {
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.05em;
  }

  .hn-erik {
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .hn-escobedo {
    font-family: var(--font-mono);
    font-weight: 300;
    color: var(--text-2);
    letter-spacing: 0.03em;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.3s;
  }

  .hero-bio {
    max-width: 560px;
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text-2);
    margin-bottom: 3rem;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.4s;
  }

  .g-google {
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.5s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--blue);
    color: #fff;
  }
  .btn-primary:hover { background: #6699f6; transform: translateY(-1px); }

  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text-2);
    background: transparent;
  }
  .btn-ghost:hover { border-color: var(--text-3); color: var(--text); }

  /* ---- Decorative grid ---- */
  .hero-decoration {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .deco-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 70% 80% at 80% 50%, black 20%, transparent 80%);
  }

  /* ---- Sections ---- */
  .section { padding: 4rem 2rem; }

  .section-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 2.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  /* ---- Timeline ---- */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
  }

  .tl-left {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  .tl-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.35rem;
  }

  .tl-year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
    white-space: nowrap;
  }

  .tl-right {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tl-company {
    font-weight: 500;
    font-size: 1rem;
    color: var(--text);
  }

  .tl-role {
    font-size: 0.85rem;
    color: var(--text-2);
    margin-bottom: 0.5rem;
  }

  .tl-desc {
    font-size: 0.9rem;
    color: var(--text-3);
    line-height: 1.65;
  }

  /* ---- Project card ---- */
  .project-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.75rem 2rem;
    background: var(--bg-2);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    max-width: 680px;
  }
  .project-card:hover {
    border-color: rgba(79, 133, 244, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(79, 133, 244, 0.08);
  }

  .project-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .project-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--blue);
  }

  .project-npm {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
  }

  .project-desc {
    font-size: 0.925rem;
    color: var(--text-2);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .ptag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-3);
  }

  .project-footer {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .project-read {
    font-size: 0.8rem;
    color: var(--text-3);
    font-family: var(--font-mono);
  }
  .project-card:hover .project-read { color: var(--blue); }

  /* ---- Post list ---- */
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .post-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
  }
  .post-row:hover .post-row-title { color: var(--blue); }

  .post-row-title {
    font-size: 0.975rem;
    color: var(--text);
    transition: color 0.15s;
  }

  .post-row-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .see-all {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-3);
    transition: color 0.15s;
  }
  .see-all:hover { color: var(--blue); }

  /* ---- Animations ---- */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .hero { padding: 4rem 1.5rem 5rem; }
    .timeline-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .tl-left { flex-direction: row-reverse; justify-content: flex-end; }
    .section { padding: 3rem 1.5rem; }
  }
</style>
