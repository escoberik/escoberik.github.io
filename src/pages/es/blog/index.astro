---
import { getCollection } from 'astro:content'
import { transformSlug } from '../../../utils/i18n'
import BlogIndex from '../../../components/BlogIndex.astro'

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.data.lang === 'es')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(p => ({ ...p, slug: transformSlug(p.slug) }))
---

<BlogIndex
  lang="es"
  title="Blog — Erik Escobedo"
  description="Notas sobre ingeniería de software, diseño de sistemas y lanzamientos de código abierto."
  altLangUrl="/blog"
  eyebrow="Notas"
  subtitle="Notas sobre ingeniería de software, diseño de sistemas y el ocasional lanzamiento de código abierto."
  postHrefPrefix="/es/blog/"
  posts={posts}
/>
