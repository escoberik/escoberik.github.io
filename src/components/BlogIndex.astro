---
import type { Lang } from '../utils/i18n'
import { getLocaleFromLang } from '../utils/i18n'
import Base from '../layouts/Base.astro'

interface Post {
  slug: string
  data: {
    title: string
    description: string
    pubDate: Date
    tags?: string[]
  }
}

interface Props {
  lang: Lang
  title: string
  description: string
  altLangUrl: string
  eyebrow: string
  subtitle: string
  postHrefPrefix: string
  posts: Post[]
}

const { lang, title, description, altLangUrl, eyebrow, subtitle, postHrefPrefix, posts } = Astro.props
const locale = getLocaleFromLang(lang)
---

<Base title={title} description={description} lang={lang} altLangUrl={altLangUrl}>
  <div class="page">
    <header class="page-header">
      <p class="page-eyebrow">{eyebrow}</p>
      <p class="page-subtitle">{subtitle}</p>
    </header>

    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`${postHrefPrefix}${post.slug}`} class="post-card">
            <div class="post-card-body">
              <h2 class="post-card-title">{post.data.title}</h2>
              <p class="post-card-desc">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-card-tags">
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <div class="post-card-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(locale, {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <span class="post-card-arrow">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

<style>
  .page {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
  }

  .page-header {
    max-width: var(--prose-w);
    margin: 0 auto 4rem;
  }

  .page-eyebrow {
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .page-subtitle {
    font-size: 1.05rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
    max-width: var(--prose-w);
    margin: 0 auto;
  }

  .post-card {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    transition: all 0.2s;
  }
  .post-card:first-of-type {
    border-top: 1px solid var(--border);
  }

  .post-card:hover .post-card-title {
    color: var(--blue);
  }
  .post-card:hover .post-card-arrow {
    color: var(--blue);
    transform: translateX(4px);
  }

  .post-card-body {
    flex: 1;
  }

  .post-card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
    transition: color 0.15s;
    line-height: 1.35;
  }

  .post-card-desc {
    font-size: 0.875rem;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .post-card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-3);
  }

  .post-card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  .post-card-meta time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-3);
    white-space: nowrap;
  }

  .post-card-arrow {
    font-size: 0.9rem;
    color: var(--text-3);
    transition:
      color 0.15s,
      transform 0.15s;
    display: inline-block;
  }

  @media (max-width: 640px) {
    .page {
      padding: 3rem 1.5rem 6rem;
    }
    .post-card {
      flex-direction: column;
      gap: 0.75rem;
    }
    .post-card-meta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
