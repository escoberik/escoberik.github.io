---
import type { Lang } from '../utils/i18n'
import { getLocaleFromLang } from '../utils/i18n'
import type { HomeData } from '../data/home'
import Base from '../layouts/Base.astro'

interface Post {
  slug: string
  data: {
    title: string
    pubDate: Date
  }
}

interface Props {
  lang: Lang
  t: HomeData
  posts: Post[]
}

const { lang, t, posts } = Astro.props
const locale = getLocaleFromLang(lang)
---

<Base title={t.pageTitle} lang={lang} altLangUrl={t.altLangUrl}>
  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">
        <span class="dot dot-blue"></span>
        <span>{t.eyebrow}</span>
      </div>
      <h1 class="hero-name">
        <span class="hn-erik"><span style="color:var(--blue)">E</span><span style="color:var(--red)">r</span><span style="color:var(--yellow)">i</span><span style="color:var(--green)">k</span></span>
        <span class="hn-escobedo">Escobedo</span>
      </h1>
      <p class="hero-title">{t.heroTitle}</p>
      <p class="hero-bio">
        {t.heroBioBefore}{' '}
        <span class="g-google">
          <span style="color:var(--blue)">G</span><span style="color:var(--red)">o</span><span style="color:var(--yellow)">o</span><span style="color:var(--blue)">g</span><span style="color:var(--green)">l</span><span style="color:var(--red)">e</span>
        </span>{' '}
        {t.heroBioAfter}
      </p>
      <div class="hero-actions">
        <a href="/resume.pdf" class="btn btn-primary" target="_blank" rel="noopener">
          {t.resumeLabel} <span class="btn-arrow">↗</span>
        </a>
        <a href={t.blogHref} class="btn btn-ghost">{t.blogLabel}</a>
        <a href="mailto:erik@escobedo.dev" class="btn btn-ghost">{t.contactLabel}</a>
      </div>
    </div>
    <div class="hero-decoration" aria-hidden="true">
      <div class="deco-grid"></div>
    </div>
  </section>

  <!-- Experience timeline -->
  <section class="section" id="experience">
    <div class="section-inner">
      <h2 class="section-label">{t.experienceLabel}</h2>
      <div class="timeline">
        {t.experience.map(item => (
          <div class="timeline-item">
            <div class="tl-left">
              <span class="tl-dot" style={`background:var(${item.highlight ? '--blue' : '--text-3'})`}></span>
              <span class="tl-year">{item.years}</span>
            </div>
            <div class="tl-right">
              <span class="tl-company">{item.company}</span>
              <span class="tl-role">{item.role}</span>
              <p class="tl-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured project -->
  <section class="section" id="open-source">
    <div class="section-inner">
      <h2 class="section-label">{t.openSourceLabel}</h2>
      <a href="https://www.npmjs.com/package/rbtrees" class="project-card" target="_blank" rel="noopener">
        <div class="project-card-header">
          <div class="project-name">rbtrees</div>
          <div class="project-npm">npm ↗</div>
        </div>
        <p class="project-desc">{t.projectDesc}</p>
        <div class="project-tags">
          <span class="ptag">React</span>
          <span class="ptag">TypeScript</span>
          <span class="ptag">SVG</span>
          <span class="ptag">Algorithms</span>
        </div>
        <div class="project-footer">
          <span class="project-read">{t.projectReadLabel}</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Writing -->
  {posts.length > 0 && (
    <section class="section" id="writing">
      <div class="section-inner">
        <h2 class="section-label">{t.writingLabel}</h2>
        <ul class="post-list">
          {posts.map(post => (
            <li>
              <a href={`${t.postHrefPrefix}${post.slug}`} class="post-row">
                <span class="post-row-title">{post.data.title}</span>
                <time class="post-row-date" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </a>
            </li>
          ))}
        </ul>
        <a href={t.seeAllHref} class="see-all">{t.seeAllLabel}</a>
      </div>
    </section>
  )}
</Base>

<script>
  const sections = Array.from(document.querySelectorAll('section[id]'))

  let hasScrolled = false
  window.addEventListener('scroll', () => { hasScrolled = true }, { once: true, passive: true })

  const observer = new IntersectionObserver((entries) => {
    if (!hasScrolled) return
    for (const entry of entries) {
      let active: Element | null = null

      if (entry.isIntersecting) {
        active = entry.target
      } else if (entry.boundingClientRect.top > (entry.rootBounds?.bottom ?? 0)) {
        const idx = sections.indexOf(entry.target)
        if (idx > 0) active = sections[idx - 1]
      }

      if (active) {
        const id = (active as HTMLElement).id
        history.replaceState(null, '', id === 'hero' ? window.location.pathname : `#${id}`)
      }
    }
  }, { rootMargin: '-15% 0px -75% 0px', threshold: 0 })

  sections.forEach(s => observer.observe(s))
</script>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: calc(100vh - 56px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 2.5rem 2rem 6rem;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.1s;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-blue {
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
    animation: pulse-dot 2.5s ease infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-name {
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    margin-left: -0.075em;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.05em;
  }

  .hn-erik {
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .hn-escobedo {
    font-family: var(--font-mono);
    font-weight: 300;
    color: var(--text-2);
    letter-spacing: 0.03em;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.3s;
  }

  .hero-bio {
    max-width: 560px;
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text-2);
    margin-bottom: 1.5rem;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.4s;
  }

  .g-google {
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fade-up 0.6s ease both;
    animation-delay: 0.5s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--blue);
    color: #fff;
  }
  .btn-primary:hover { background: #6699f6; transform: translateY(-1px); }

  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text-2);
    background: transparent;
  }
  .btn-ghost:hover { border-color: var(--text-3); color: var(--text); }

  /* ---- Decorative grid ---- */
  .hero-decoration {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .deco-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 70% 80% at 80% 50%, black 20%, transparent 80%);
  }

  /* ---- Sections ---- */
  .section { padding: 4rem 2rem; }

  .section-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 2.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  /* ---- Timeline ---- */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
  }

  .tl-left {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  .tl-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.35rem;
  }

  .tl-year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
    white-space: nowrap;
  }

  .tl-right {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tl-company {
    font-weight: 500;
    font-size: 1rem;
    color: var(--text);
  }

  .tl-role {
    font-size: 0.85rem;
    color: var(--text-2);
    margin-bottom: 0.5rem;
  }

  .tl-desc {
    font-size: 0.9rem;
    color: var(--text-3);
    line-height: 1.65;
  }

  /* ---- Project card ---- */
  .project-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.75rem 2rem;
    background: var(--bg-2);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    max-width: 680px;
  }
  .project-card:hover {
    border-color: rgba(79, 133, 244, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(79, 133, 244, 0.08);
  }

  .project-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .project-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--blue);
  }

  .project-npm {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
  }

  .project-desc {
    font-size: 0.925rem;
    color: var(--text-2);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .ptag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-3);
  }

  .project-footer {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .project-read {
    font-size: 0.8rem;
    color: var(--text-3);
    font-family: var(--font-mono);
  }
  .project-card:hover .project-read { color: var(--blue); }

  /* ---- Post list ---- */
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .post-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
  }
  .post-row:hover .post-row-title { color: var(--blue); }

  .post-row-title {
    font-size: 0.975rem;
    color: var(--text);
    transition: color 0.15s;
  }

  .post-row-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .see-all {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-3);
    transition: color 0.15s;
  }
  .see-all:hover { color: var(--blue); }

  /* ---- Animations ---- */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .hero { padding: 2rem 1.5rem 5rem; align-items: flex-start; }
    .hero-bio { height: calc(1.1rem * 1.75 * 6); overflow: hidden; }
    .hero-actions { flex-direction: column; }
    .btn { width: 100%; justify-content: center; }
    .timeline-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .tl-left { flex-direction: row-reverse; justify-content: flex-end; }
    .section { padding: 3rem 1.5rem; }
  }
</style>
